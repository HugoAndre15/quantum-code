# ─── Base de données ─────────────────────────────────────────────────────────
# URL de connexion PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quantum_code"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change_me_jwt_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Admin par défaut (utilisé par prisma/seed.ts) ───────────────────────────
ADMIN_EMAIL="admin@quantumcode.dev"
ADMIN_PASSWORD="VotreMotDePasseSecurise!"
ADMIN_NAME="Admin Quantum Code"

# ─── Serveur ─────────────────────────────────────────────────────────────────
PORT=3001

# URL du frontend autorisée par la politique CORS (séparées par des virgules si plusieurs)
# Exemple production: FRONTEND_URL="https://quantum-code-theta.vercel.app"
FRONTEND_URL="http://localhost:3000"

# ─── Mail (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="contact@quantumcode.dev"
