# ─── Base de données ─────────────────────────────────────────────────────────
# URL de connexion PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quantum_code"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change_me_jwt_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Admin par défaut (utilisé par prisma/seed.ts) ───────────────────────────
ADMIN_EMAIL="admin@quantumcode.dev"
ADMIN_PASSWORD="VotreMotDePasseSecurise!"
ADMIN_NAME="Admin Quantum Code"

# ─── Serveur ─────────────────────────────────────────────────────────────────
PORT=3001

# URL du frontend autorisée par la politique CORS (séparées par des virgules si plusieurs)
# ⚠️  En production (Railway), cette variable DOIT correspondre à l'URL réelle du frontend.
# Exemple production: FRONTEND_URL="https://quantum-code-theta.vercel.app"
# Plusieurs origines: FRONTEND_URL="https://quantum-code-theta.vercel.app,http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# ─── Mail (SMTP — Zoho) ──────────────────────────────────────────────────────
SMTP_HOST="smtp.zoho.eu"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="contact@quantum-code.fr"
SMTP_PASS="your_zoho_password"
SMTP_FROM="contact@quantum-code.fr"
